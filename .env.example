# カスタムサーバーの待受ポート (デフォルト 3000)
PORT=3000

# カスタムサーバーの待受ホスト (デフォルト 0.0.0.0)
HOSTNAME=0.0.0.0

# Colyseus /monitor の Basic 認証パスワード (admin / この値)
# 未指定の場合は backend constants の DEBUG_ADMIN_PASSWORD ("admin") が使われる
ADMIN_PASSWORD=admin

# 本番で Colyseus サーバーを別ホスト/ポートにする場合のみ指定。
# ローカル開発では空のままで OK (同一オリジンに接続する)
# 例: NEXT_PUBLIC_SERVER_URL=wss://bombompanic.example.com
NEXT_PUBLIC_SERVER_URL=
