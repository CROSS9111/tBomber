{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.server.json server.ts",
    "build": "next build --webpack",
    "start": "cross-env NODE_ENV=production tsx --tsconfig tsconfig.server.json server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@colyseus/monitor": "^0.14.22",
    "@colyseus/schema": "^1.0.45",
    "@faker-js/faker": "^7.6.0",
    "colyseus": "^0.14.24",
    "colyseus.js": "^0.14.13",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "matter-js": "^0.18.0",
    "next": "^16.2.6",
    "pathfinding": "^0.4.18",
    "phaser": "3.55.2",
    "phaser3-rex-plugins": "1.1.79",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "timesync": "^1.0.11",
    "tsx": "^4.19.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.15",
    "@types/matter-js": "^0.18.2",
    "@types/node": "^20.11.30",
    "@types/pathfinding": "^0.0.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "terser-webpack-plugin": "^5.6.0",
    "typescript": "^5.4.5"
  }
}
